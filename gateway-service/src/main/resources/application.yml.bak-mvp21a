server:
  port: 8080

spring:
  application:
    name: gateway-service
  cloud:
    gateway:
      routes:
        - id: student-route
          uri: lb://STUDENT-SERVICE
          predicates:
            - Path=/api/students/**
        - id: tenant-route
          uri: lb://TENANT-SERVICE
          predicates:
            - Path=/api/tenants/**

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/
